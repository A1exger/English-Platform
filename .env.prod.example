# Copy to .env.prod and fill in. Used by docker-compose.prod.yml.

# --- Database / cache ---
POSTGRES_USER=linguadesk
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=linguadesk

# --- Auth (generate long random values, e.g. `openssl rand -hex 32`) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Web <-> API ---
# Public URL of the API as seen by the browser (used both for CORS and baked
# into the web client at build time).
CORS_ORIGIN=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1

# --- Reverse proxy / TLS (only needed with docker-compose.caddy.yml) ---
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

# Allow creating admin accounts via /auth/register (keep empty/false in prod;
# admins are created by the seed). Set to "true" only for controlled bootstraps.
ALLOW_ADMIN_REGISTRATION=

# --- Payments (optional for first deploy) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_WEBHOOK_SECRET=

# --- Video (LiveKit Cloud) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
