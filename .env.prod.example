# Copy to .env.prod and fill in. Used by docker-compose.prod.yml.

# --- Database / cache ---
POSTGRES_USER=linguadesk
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=linguadesk

# --- Auth (generate long random values, e.g. `openssl rand -hex 32`) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Web <-> API (single domain: frontend + API under /api) ---
# Public URL of the API as seen by the browser (used both for CORS and baked
# into the web client at build time).
CORS_ORIGIN=https://englishsparkstudio.com
NEXT_PUBLIC_API_URL=https://englishsparkstudio.com/api/v1

# --- Reverse proxy / TLS (only needed with docker-compose.caddy.yml) ---
DOMAIN=englishsparkstudio.com
ACME_EMAIL=admin@englishsparkstudio.com

# Allow creating admin accounts via /auth/register (keep empty/false in prod;
# admins are created by the seed). Set to "true" only for controlled bootstraps.
ALLOW_ADMIN_REGISTRATION=

# --- Payments (optional for first deploy) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_WEBHOOK_SECRET=

# --- Video (LiveKit Cloud) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=

# --- AI course generation (optional; without a key generation is disabled) ---
ANTHROPIC_API_KEY=
# Model + concurrency for the generator (defaults are sensible).
ANTHROPIC_MODEL=claude-sonnet-5
AI_MAX_CONCURRENCY=3

# --- Western Union / MoneyGram (manual transfers) ---
TRANSFER_RECEIVER_NAME=LinguaDesk Ltd.
TRANSFER_RECEIVER_COUNTRY=Germany

# --- Prebuilt images from GHCR (only for docker-compose.ghcr.yml) ---
IMAGE_OWNER=a1exger/english-platform
IMAGE_TAG=latest
