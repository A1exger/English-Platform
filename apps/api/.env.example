# Database
# Dev/test uses SQLite. PRODUCTION uses PostgreSQL, e.g.:
#   DATABASE_URL="postgresql://user:pass@host:5432/english_platform?schema=public"
DATABASE_URL="file:./dev.db"

# JWT
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Payments (Stripe + PayPal). Webhook secrets are used to verify signatures.
STRIPE_SECRET_KEY="sk_test_change_me"
STRIPE_WEBHOOK_SECRET="whsec_dev_change_me"
PAYPAL_CLIENT_ID="paypal-client-id"
PAYPAL_SECRET="paypal-secret"
PAYPAL_WEBHOOK_SECRET="paypal-webhook-secret-dev"

# Video (LiveKit Cloud)
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret"

# Telegram bot (optional). Without a token, telegram notifications are skipped.
TELEGRAM_BOT_TOKEN=""

# Western Union / MoneyGram receiver shown in transfer instructions.
TRANSFER_RECEIVER_NAME="LinguaDesk Ltd."
TRANSFER_RECEIVER_COUNTRY="Germany"
