# Database
# Dev/test uses SQLite. PRODUCTION uses PostgreSQL, e.g.:
#   DATABASE_URL="postgresql://user:pass@host:5432/english_platform?schema=public"
DATABASE_URL="file:./dev.db"

# JWT
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
